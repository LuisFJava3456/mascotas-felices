generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model asignacion_veterinarios {
  asignacion_id  Int           @id @default(autoincrement())
  veterinario_id BigInt?
  sucursal_id    Int?
  dia_semana     String?       @db.VarChar(10)
  sucursales     sucursales?   @relation(fields: [sucursal_id], references: [sucursal_id], onDelete: NoAction, onUpdate: NoAction)
  veterinarios   veterinarios? @relation(fields: [veterinario_id], references: [veterinario_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([veterinario_id, sucursal_id])
}

model citas {
  cita_id      BigInt      @id @default(autoincrement())
  fecha_hora   DateTime    @db.Timestamptz(6)
  mascota_id   BigInt?
  sucursal_id  Int?
  motivo_breve String?
  mascotas     mascotas?   @relation(fields: [mascota_id], references: [mascota_id], onDelete: NoAction, onUpdate: NoAction)
  sucursales   sucursales? @relation(fields: [sucursal_id], references: [sucursal_id], onDelete: NoAction, onUpdate: NoAction)
  consultas    consultas[]
}

model ciudades {
  ciudad_id     Int            @id @default(autoincrement())
  nombre_ciudad String
  estado        String
  propietarios  propietarios[]
  sucursales    sucursales[]
}

model consultas {
  consulta_id       BigInt       @id @default(autoincrement())
  cita_id           BigInt?
  motivo_consulta   String
  sintomas          String
  diagnostico       String
  tratamiento       String?
  mascota_id        BigInt
  veterinario_id    BigInt
  sucursal_id       Int
  fecha_realizacion DateTime?    @default(now()) @db.Timestamptz(6)
  citas             citas?       @relation(fields: [cita_id], references: [cita_id], onUpdate: NoAction)
  mascotas          mascotas     @relation(fields: [mascota_id], references: [mascota_id], onDelete: NoAction, onUpdate: NoAction)
  sucursales        sucursales   @relation(fields: [sucursal_id], references: [sucursal_id], onDelete: NoAction, onUpdate: NoAction)
  veterinarios      veterinarios @relation(fields: [veterinario_id], references: [veterinario_id], onDelete: NoAction, onUpdate: NoAction)
  facturas          facturas?
  receta            receta[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model detalle_factura {
  id_detalle      BigInt     @id @default(autoincrement())
  factura_id      BigInt?
  producto_id     BigInt?
  servicio_id     Int?
  cantidad        Int
  precio_unitario Decimal    @db.Decimal(12, 2)
  subtotal        Decimal?   @default(dbgenerated("((cantidad)::numeric * precio_unitario)")) @db.Decimal(12, 2)
  facturas        facturas?  @relation(fields: [factura_id], references: [factura_id], onDelete: Cascade, onUpdate: NoAction)
  productos       productos? @relation(fields: [producto_id], references: [producto_id], onDelete: NoAction, onUpdate: NoAction)
  servicios       servicios? @relation(fields: [servicio_id], references: [servicio_id], onDelete: NoAction, onUpdate: NoAction)
}

model detalle_receta {
  id_detalle         BigInt     @id @default(autoincrement())
  id_receta          BigInt?
  producto_id        BigInt?
  dosis              String
  frecuencia         String
  duracion           String
  indicaciones_extra String?
  receta             receta?    @relation(fields: [id_receta], references: [id_receta], onDelete: Cascade, onUpdate: NoAction)
  productos          productos? @relation(fields: [producto_id], references: [producto_id], onDelete: NoAction, onUpdate: NoAction)
}

model especialidades {
  especialidad_id     Int            @id @default(autoincrement())
  nombre_especialidad String         @unique
  veterinarios        veterinarios[]
}

model especies {
  especie_id     Int        @id @default(autoincrement())
  nombre_especie String     @unique
  mascotas       mascotas[]
  razas          razas[]
}

model estados_pago {
  id_estado     Int        @id @default(autoincrement())
  nombre_estado String     @unique
  facturas      facturas[]
}

model facturas {
  factura_id      BigInt            @id @default(autoincrement())
  fecha_emision   DateTime?         @default(now()) @db.Timestamptz(6)
  monto_total     Decimal?          @default(0) @db.Decimal(12, 2)
  id_estado       Int?
  cliente_id      BigInt?
  sucursal_id     Int?
  consulta_id     BigInt?           @unique
  detalle_factura detalle_factura[]
  propietarios    propietarios?     @relation(fields: [cliente_id], references: [propietario_id], onDelete: NoAction, onUpdate: NoAction)
  consultas       consultas?        @relation(fields: [consulta_id], references: [consulta_id], onDelete: NoAction, onUpdate: NoAction)
  estados_pago    estados_pago?     @relation(fields: [id_estado], references: [id_estado], onDelete: NoAction, onUpdate: NoAction)
  sucursales      sucursales?       @relation(fields: [sucursal_id], references: [sucursal_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model mascotas {
  mascota_id       BigInt       @id @default(autoincrement())
  nombre           String
  fecha_nacimiento DateTime?    @db.Date
  sexo             String?      @db.Char(1)
  propietario_id   BigInt
  especie_id       Int?
  raza_id          Int?
  fecha_registro   DateTime?    @default(now()) @db.Timestamptz(6)
  activo           Boolean?     @default(true)
  citas            citas[]
  consultas        consultas[]
  especies         especies?    @relation(fields: [especie_id], references: [especie_id], onDelete: NoAction, onUpdate: NoAction)
  propietarios     propietarios @relation(fields: [propietario_id], references: [propietario_id], onDelete: Cascade, onUpdate: NoAction)
  razas            razas?       @relation(fields: [raza_id], references: [raza_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model productos {
  producto_id          BigInt            @id @default(autoincrement())
  nombre               String
  descripcion          String?
  precio_venta         Decimal           @db.Decimal(12, 2)
  stock_actual         Int?              @default(0)
  stock_minimo         Int?              @default(5)
  sucursal_id          Int?
  activo               Boolean?          @default(true)
  fecha_ultimo_ingreso DateTime?         @default(now()) @db.Timestamptz(6)
  detalle_factura      detalle_factura[]
  detalle_receta       detalle_receta[]
  sucursales           sucursales?       @relation(fields: [sucursal_id], references: [sucursal_id], onDelete: NoAction, onUpdate: NoAction)
}

model propietarios {
  propietario_id       BigInt      @id @default(autoincrement())
  nombre               String
  primerap             String
  segundoap            String?
  telefono             BigInt?
  email                String      @unique
  calle_numero         String?
  codigo_postal        String?     @db.VarChar(10)
  ciudad_id            Int?
  sucursal_registro_id Int?
  fecha_registro       DateTime?   @default(now()) @db.Timestamptz(6)
  activo               Boolean?    @default(true)
  facturas             facturas[]
  mascotas             mascotas[]
  ciudades             ciudades?   @relation(fields: [ciudad_id], references: [ciudad_id], onDelete: NoAction, onUpdate: NoAction)
  sucursales           sucursales? @relation(fields: [sucursal_registro_id], references: [sucursal_id], onDelete: NoAction, onUpdate: NoAction)
}

model razas {
  raza_id     Int        @id @default(autoincrement())
  nombre_raza String
  especie_id  Int?
  mascotas    mascotas[]
  especies    especies?  @relation(fields: [especie_id], references: [especie_id], onDelete: NoAction, onUpdate: NoAction)
}

model receta {
  id_receta         BigInt           @id @default(autoincrement())
  fecha_emision     DateTime?        @default(now()) @db.Timestamptz(6)
  fecha_vencimiento DateTime?        @db.Date
  consulta_id       BigInt
  detalle_receta    detalle_receta[]
  consultas         consultas        @relation(fields: [consulta_id], references: [consulta_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model servicios {
  servicio_id               Int               @id @default(autoincrement())
  nombre_servicio           String            @unique
  descripcion               String?
  precio_base               Decimal           @db.Decimal(12, 2)
  activo                    Boolean?          @default(true)
  duracion_estimada_minutos Int?
  detalle_factura           detalle_factura[]
}

model sucursales {
  sucursal_id             Int                       @id @default(autoincrement())
  nombre_sucursal         String
  direccion_sucursal      String?
  ciudad_id               Int?
  asignacion_veterinarios asignacion_veterinarios[]
  citas                   citas[]
  consultas               consultas[]
  facturas                facturas[]
  productos               productos[]
  propietarios            propietarios[]
  ciudades                ciudades?                 @relation(fields: [ciudad_id], references: [ciudad_id], onDelete: NoAction, onUpdate: NoAction)
}

model veterinarios {
  veterinario_id          BigInt                    @id @default(autoincrement())
  nombres                 String
  primerap                String
  segundoap               String?
  cedula_profesional      String                    @unique
  especialidad_id         Int?
  activo                  Boolean?                  @default(true)
  asignacion_veterinarios asignacion_veterinarios[]
  consultas               consultas[]
  especialidades          especialidades?           @relation(fields: [especialidad_id], references: [especialidad_id], onDelete: NoAction, onUpdate: NoAction)
}
